extends ../layouts/default.pug
include ../mixins/checkbox.pug
include ../mixins/box-pagination.pug

block title
  title Quản lý tour

block main
  .box-title Quản lý tour

  //- Section 4
  .section-4
    .inner-wrap
      .inner-item
        <i class="fa-solid fa-filter"></i>
        | Bộ lọc
      .inner-item
        select(name="")
          option(value="") Trạng thái
      .inner-item
        select(name="")
          option(value="") Người tạo
      .inner-item
        input(type="date", name="")
        span -
        input(type="date", name="")
      .inner-item
        select(name="")
          option(value="") Danh mục
      .inner-item
        select(name="")
          option(value="") Mức giá
      .inner-item.inner-reset
        <i class="fa-solid fa-rotate-left"></i>
        | Xóa bộ lọc
  //- End Section 4

  //- Section 5
  .section-5
    .inner-wrap
      form.inner-change-status
        select(name="")
          option(value="") -- Hành động --
        button Áp dụng
      form.inner-search
        button <i class="fa-solid fa-magnifying-glass"></i>
        input(type="text", name="", placeholder="Tìm kiếm")
      a.inner-create(href="#") + Tạo mới
      a.inner-trash(href="#") Thùng rác
  //- End Section 5

  //- Section 6
  .section-6
    .table-2
      table
        thead
          tr
            th
              +checkbox-28("#check-all")
            th Tên tour
            th Ảnh đại diện
            th Giá
            th Còn lại
            th Vị trí
            th Trạng thái
            th Tạo bởi
            th Cập nhật bởi
            th Hành động
        tbody
          tr
            td
              +checkbox-28("#check-1")
            td Danh mục 1
            td
              img(src="assets/images/tour-1.png", alt="")
            td
              div NL: 1.900.000đ
              div TE: 1.600.000đ
              div EB: 1.000.000đ
            td
              div NL: 30
              div TE: 20
              div EB: 10
            td 1
            td
              .tag.tag-red Tạm dừng
            td
              div Lê Văn A
              .inner-time 16:30 - 20/10/2024
            td
              div Lê Văn A
              .inner-time 16:30 - 20/10/2024
            td
              .box-action
                a.inner-edit(href="#") <i class="fa-solid fa-pen-to-square"></i>
                a.inner-trash(href="#") <i class="fa-solid fa-trash-can"></i>
          tr
            td
              +checkbox-28("#check-2")
            td Danh mục 2
            td
              img(src="assets/images/tour-1.png", alt="")
            td
              div NL: 1.900.000đ
              div TE: 1.600.000đ
              div EB: 1.000.000đ
            td
              div NL: 30
              div TE: 20
              div EB: 10
            td 1
            td
              .tag.tag-green Hoạt động
            td
              div Lê Văn A
              .inner-time 16:30 - 20/10/2024
            td
              div Lê Văn A
              .inner-time 16:30 - 20/10/2024
            td
              .box-action
                a.inner-edit(href="#") <i class="fa-solid fa-pen-to-square"></i>
                a.inner-trash(href="#") <i class="fa-solid fa-trash-can"></i>
  //- End Section 6

  //- Box Pagination
  +box-pagination()
  //- Box Pagination